# Copy this file to `.env` and fill in only what you use. Never commit `.env`.

# --- Databento historical data (research/fetch_databento.py) ---------------
DATABENTO_API_KEY=

# --- Discord notifications -------------------------------------------------
# Server Settings -> Integrations -> Webhooks -> New Webhook -> Copy URL
DISCORD_WEBHOOK_URL=

# --- ProjectX / TopstepX (broker=projectx) ---------------------------------
# Create an API key in your TopstepX/ProjectX dashboard.
# COMPLIANCE: TopstepX bans VPS/VPN/remote servers — run on your own device.
PROJECTX_USERNAME=
PROJECTX_API_KEY=
PROJECTX_ACCOUNT=
# Base URL differs per firm; TopstepX example shown:
PROJECTX_BASE_URL=https://api.topstepx.com

# --- TradersPost (broker=traderspost) — the route for Lucid Trading --------
# Create a strategy in TradersPost, connect Lucid via Tradovate, copy the
# webhook URL here. Local P/L will be an ESTIMATE; reconcile on your platform.
TRADERSPOST_WEBHOOK_URL=
TRADERSPOST_SECRET=

# --- Rithmic live feed (feed=rithmic) --------------------------------------
# Requires your own Rithmic gateway credentials (~$125/mo R|API package on a
# personal broker account; prop accounts must be API-enabled by the firm).
RITHMIC_USER=
RITHMIC_PASSWORD=
RITHMIC_SYSTEM=Rithmic Paper Trading
RITHMIC_GATEWAY=Rithmic Paper Trading
